# ─── Desarrollo ───────────────────────────────────────────────────────────────
# El proxy de Vite redirige /api/* → https://api-clientes-dev.cootranstame.net
# VITE_API_BASE_URL se deja vacío para que constants.tsx use '/api' (proxy)
VITE_API_BASE_URL=

# Backend de desarrollo (usado por el proxy de Vite en vite.config.ts)
VITE_API_PROXY_TARGET=https://api-clientes-dev.cootranstame.net
